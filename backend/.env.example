# Integrall Backend Configuration
# Copy to .env and fill in your values

# Database
DATABASE_URL=sqlite+aiosqlite:///./integrall.db
# For PostgreSQL (v1.0): postgresql+asyncpg://user:password@localhost/integrall

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
API_KEY=your-iot-device-api-key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# IoT Settings
DEVICE_POLL_INTERVAL_SECONDS=3
COMMAND_TIMEOUT_SECONDS=30
MAX_DEVICES=1000
