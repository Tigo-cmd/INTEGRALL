    }
  ],
  "license": "MIT",
  "homepage": "https://integrall.io",
  "dependencies": {
    "bblanchon/ArduinoJson": "^6.21.3"
  },
  "frameworks": "arduino",
  "platforms": "espressif32",
  "examples": [
    {
