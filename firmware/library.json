  "keywords": "iot, esp32, framework, relay, keypad, oled, automation",
  "repository": {
    "type": "git",
    "url": "https://github.com/emmanueltigo/integrall.git"
  },
  "authors": [
    {
      "name": "Emmanuel TIGO",
