Adafruit_SSD1306* getDisplay() { return integrall.oled.getRaw(); }

void drawCenteredText(const char* text, int textSize) {
  int16_t x1, y1; uint16_t w, h;
  getDisplay()->setTextSize(textSize);
  getDisplay()->getTextBounds((char*)text, 0, 0, &x1, &y1, &w, &h);
  getDisplay()->setCursor((128 - w) / 2, (64 - h) / 2);
  getDisplay()->print(text);
}

void showTwoLines(const String &l1, const String &l2) {
  getDisplay()->clearDisplay();
  getDisplay()->setCursor(0, 10);
  getDisplay()->println(l1);
  getDisplay()->println(l2);
  getDisplay()->display();
}

void chooseMode() {
  getDisplay()->clearDisplay();
  drawCenteredText("Choose Scan Mode", 1);
  getDisplay()->setCursor(2, 52); getDisplay()->print("PORT Btn -> Serial");
  getDisplay()->setCursor(2, 58); getDisplay()->print("WEB  Btn -> WiFi");
  getDisplay()->display();

  while (true) {
    if (digitalRead(BUTTON_PORT) == LOW) {
      currentMode = MODE_PORT;
      showTwoLines("Mode:", "PORT (Serial)"); delay(700); break;
    } else if (digitalRead(BUTTON_WEB) == LOW) {
      currentMode = MODE_WEB;
      showTwoLines("Mode:", "WEB (WiFi) -> Connecting...");
      
      // 5. Integrall WiFi Management
      // Replaces 10 lines of while() loops and delay() checks!
      integrall.begin(ssid, password);
      
      if (integrall.isOnline()) {
        showTwoLines("WiFi connected:", integrall.getIPAddress());
      } else {
        showTwoLines("WiFi failed", "Check creds");
      }
      delay(800); break;
    }
    animateCircularDots();
    delay(30);
  }
}

